<?xml version="1.0" encoding="UTF-8"?>
<!-- Example: Subreport used by MasterReport for JaspertReport multi-tenant engine -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="DetailReport" language="java"
              pageWidth="555" pageHeight="842"
              columnWidth="555" leftMargin="0" rightMargin="0"
              topMargin="0" bottomMargin="0"
              uuid="c3d4e5f6-a7b8-9012-cdef-123456789012">

    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>

    <parameter name="DS_DATOS" forPrompting="false"
               class="net.sf.jasperreports.engine.JRDataSource"/>

    <query language="sql"><![CDATA[]]></query>

    <field name="id"       class="java.lang.String"/>
    <field name="nombre"   class="java.lang.String"/>
    <field name="cantidad" class="java.lang.String"/>
    <field name="precio"   class="java.lang.String"/>

    <columnHeader>
        <band height="20">
            <element kind="staticText" uuid="dh1-uuid" x="0"   y="2" width="40"  height="16">
                <textElement><font fontName="Arial" size="9" isBold="true"/></textElement>
                <text><![CDATA[ID]]></text>
            </element>
            <element kind="staticText" uuid="dh2-uuid" x="50"  y="2" width="200" height="16">
                <textElement><font fontName="Arial" size="9" isBold="true"/></textElement>
                <text><![CDATA[Item]]></text>
            </element>
            <element kind="staticText" uuid="dh3-uuid" x="260" y="2" width="80"  height="16">
                <textElement textAlignment="Right">
                    <font fontName="Arial" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Qty]]></text>
            </element>
            <element kind="staticText" uuid="dh4-uuid" x="350" y="2" width="100" height="16">
                <textElement textAlignment="Right">
                    <font fontName="Arial" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Price]]></text>
            </element>
            <element kind="staticText" uuid="dh5-uuid" x="460" y="2" width="95"  height="16">
                <textElement textAlignment="Right">
                    <font fontName="Arial" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Total]]></text>
            </element>
        </band>
    </columnHeader>

    <detail>
        <band height="18">
            <element kind="textField" uuid="dd1-uuid" x="0"   y="1" width="40"  height="16">
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </element>
            <element kind="textField" uuid="dd2-uuid" x="50"  y="1" width="200" height="16">
                <textFieldExpression><![CDATA[$F{nombre}]]></textFieldExpression>
            </element>
            <element kind="textField" uuid="dd3-uuid" x="260" y="1" width="80"  height="16">
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$F{cantidad}]]></textFieldExpression>
            </element>
            <element kind="textField" uuid="dd4-uuid" x="350" y="1" width="100" height="16">
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$F{precio}]]></textFieldExpression>
            </element>
            <element kind="textField" uuid="dd5-uuid" x="460" y="1" width="95"  height="16">
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    new java.math.BigDecimal(
                        $F{cantidad} != null ? $F{cantidad} : "0"
                    ).multiply(
                        new java.math.BigDecimal(
                            $F{precio} != null ? $F{precio} : "0"
                        )
                    )
                ]]></textFieldExpression>
            </element>
        </band>
    </detail>

</jasperReport>
