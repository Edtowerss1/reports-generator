<!-- Example: Master report with subreport for JaspertReport multi-tenant engine -->
<jasperReport name="MasterReport" language="java" columnCount="1" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="b2c3d4e5-f6a7-8901-bcde-f12345678901">
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>
    <parameter name="DS_EMPRESA" forPrompting="false" class="net.sf.jasperreports.engine.data.JRMapCollectionDataSource"/>
    <parameter name="DS_DATOS" forPrompting="false" class="net.sf.jasperreports.engine.JRDataSource"/>
    <parameter name="SUBREPORT_DIR" class="java.lang.String"/>
    <query language="sql"><![CDATA[]]></query>
    <title height="70">
        <element kind="staticText" uuid="b2c3d4e5-0001-4000-8000-000000000001" x="0" y="5" width="555" height="25" hTextAlign="Center" fontName="Arial" fontSize="14.0" bold="true">
            <text><![CDATA[Sample Report — Master with Subreport]]></text>
        </element>
        <element kind="textField" uuid="b2c3d4e5-0002-4000-8000-000000000002" x="0" y="35" width="555" height="15" hTextAlign="Center" fontName="Arial" fontSize="9.0">
                <expression><![CDATA[$P{DS_EMPRESA}.getData().isEmpty() ? "Demo Company" : (String)$P{DS_EMPRESA}.getData().iterator().next().get("nombre")]]></expression>
        </element>
        <element kind="line" uuid="b2c3d4e5-0003-4000-8000-000000000003" x="0" y="60" width="555" height="1"/>
    </title>
    <detail>
        <band height="40" splitType="Stretch">
            <element kind="subreport" uuid="b2c3d4e5-0004-4000-8000-000000000004" x="0" y="0" width="555" height="38">
                <dataSourceExpression><![CDATA[$P{DS_DATOS}]]></dataSourceExpression>
                <expression><![CDATA[$P{SUBREPORT_DIR} + "DetailReport.jasper"]]></expression>
            </element>
        </band>
    </detail>
    <pageFooter height="20">
        <element kind="textField" uuid="b2c3d4e5-0005-4000-8000-000000000005" x="455" y="2" width="100" height="16" fontName="Arial" fontSize="8.0" hTextAlign="Right">
            <expression><![CDATA["Page " + $V{PAGE_NUMBER}]]></expression>
        </element>
    </pageFooter>
</jasperReport>
